{
  "name": "tinytop",
  "version": "0.1.31",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "setup": "bun run src/wizard/index.ts",
    "dev": "bun run src/server.ts",
    "start": "bun run src/server.ts",
    "collector": "bun run legacy/bun-collector.ts",
    "collector:check": "bun run legacy/bun-collector.ts --check",
    "writer": "bun run collector",
    "writer:check": "bun run collector:check",
    "test": "bun test",
    "check:bun": "bun test && bun run src/server.ts --check && bun run legacy/bun-collector.ts --check",
    "check:rust": "cargo fmt --manifest-path agent/Cargo.toml --all -- --check && cargo test --manifest-path agent/Cargo.toml --workspace",
    "check": "bun run check:bun && bun run check:rust",
    "rust:build": "cargo build --release --manifest-path agent/Cargo.toml -p tinytop-agent",
    "rust:test": "cargo test --manifest-path agent/Cargo.toml --workspace",
    "rust:collect": "cargo run --manifest-path agent/Cargo.toml -p tinytop-agent -- collect --json",
    "rust:serve": "cargo run --manifest-path agent/Cargo.toml -p tinytop-agent -- serve",
    "rust:serve-writer": "cargo run --manifest-path agent/Cargo.toml -p tinytop-agent -- serve-writer"
  },
  "dependencies": {
    "echarts": "^6.1.0"
  }
}
