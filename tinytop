#!/usr/bin/env bash
set -Eeuo pipefail

TINYTOP_VERSION="0.1.32"
INSTALL_BUN_COMMAND='curl -fsSL https://bun.com/install | bash'
INSTALL_RUST_COMMAND='curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs | sh'

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
PLAIN=0
if [[ "${NO_COLOR:-}" != "" ]]; then PLAIN=1; fi
if [[ "${1:-}" == "--plain" ]]; then PLAIN=1; shift; fi

if [[ "$PLAIN" -eq 0 && -t 1 ]]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_BLUE=$'\033[34m'
else
  C_RESET=""
  C_BOLD=""
  C_GREEN=""
  C_YELLOW=""
  C_RED=""
  C_BLUE=""
fi

command_name="${1:-help}"
if [[ "$#" -gt 0 ]]; then shift; fi

say() { printf '%s\n' "$*"; }
info() { printf '%s%s%s\n' "$C_BLUE" "$*" "$C_RESET"; }
ok() { printf '%s%s%s\n' "$C_GREEN" "$*" "$C_RESET"; }
warn() { printf '%s%s%s\n' "$C_YELLOW" "$*" "$C_RESET" >&2; }
fail() { printf '%s%s%s\n' "$C_RED" "$*" "$C_RESET" >&2; }
die() { fail "$*"; exit 1; }

bun_path() {
  command -v bun 2>/dev/null || true
}

cargo_path() {
  command -v cargo 2>/dev/null || true
}

curl_path() {
  command -v curl 2>/dev/null || true
}

require_bun() {
  if [[ -z "$(bun_path)" ]]; then
    die "Bun is required for this command. Run: ./tinytop install-bun --yes"
  fi
}

require_cargo() {
  if [[ -z "$(cargo_path)" ]]; then
    die "Rust/Cargo is required for this command. Install Rust with: $INSTALL_RUST_COMMAND
Docs: https://rustup.rs"
  fi
}

rust_agent_target_bin() {
  printf '%s/agent/target/release/tinytop-agent%s\n' "$ROOT_DIR" "$(rust_binary_extension)"
}

rust_agent_local_bin() {
  printf '%s/.local/bin/tinytop-agent%s\n' "$HOME" "$(rust_binary_extension)"
}

rust_agent_exec() {
  if [[ -n "${TINYTOP_AGENT_BIN:-}" && -x "${TINYTOP_AGENT_BIN:-}" ]]; then
    printf '%s\n' "$TINYTOP_AGENT_BIN"
    return
  fi

  local target_bin
  target_bin="$(rust_agent_target_bin)"
  if [[ -x "$target_bin" ]]; then
    printf '%s\n' "$target_bin"
    return
  fi

  local local_bin
  local_bin="$(rust_agent_local_bin)"
  if [[ -x "$local_bin" ]]; then
    printf '%s\n' "$local_bin"
    return
  fi

  printf '%s\n' "$target_bin"
}

rust_agent_available() {
  local agent_bin
  agent_bin="$(rust_agent_exec)"
  [[ -x "$agent_bin" || -n "$(cargo_path)" ]]
}

selected_runtime() {
  local requested="${TINYTOP_RUNTIME:-auto}"
  case "$requested" in
    auto|"")
      if rust_agent_available; then
        printf 'rust\n'
      elif [[ -n "$(bun_path)" ]]; then
        printf 'legacy\n'
      else
        die "No TinyTop runtime is available. Run ./tinytop rust install-binary, ./tinytop install-rust --print-only, or ./tinytop install-bun --yes"
      fi
      ;;
    rust)
      rust_agent_available || die "Rust collector is not available. Run ./tinytop rust install-binary or ./tinytop rust build"
      printf 'rust\n'
      ;;
    bun|legacy|legacy-bun)
      [[ -n "$(bun_path)" ]] || die "Bun is required for legacy runtime. Run: ./tinytop install-bun --yes"
      printf 'legacy\n'
      ;;
    *)
      die "Unknown TINYTOP_RUNTIME=$requested. Use auto, rust, legacy, or bun."
      ;;
  esac
}

rust_release_os() {
  if [[ -n "${TINYTOP_RELEASE_OS:-}" ]]; then
    printf '%s' "$TINYTOP_RELEASE_OS"
    return
  fi

  case "$(uname -s)" in
    Linux) printf 'linux' ;;
    Darwin) printf 'macos' ;;
    MINGW*|MSYS*|CYGWIN*) printf 'windows' ;;
    *) uname -s | tr '[:upper:]' '[:lower:]' ;;
  esac
}

rust_binary_extension() {
  if [[ "$(rust_release_os)" == "windows" ]]; then
    printf '.exe'
  fi
}

rust_release_arch() {
  case "$(uname -m)" in
    x86_64|amd64) printf 'x86_64' ;;
    aarch64|arm64) printf 'aarch64' ;;
    *) uname -m ;;
  esac
}

rust_release_asset_name() {
  local os arch extension
  os="$(rust_release_os)"
  arch="$(rust_release_arch)"
  extension=""
  if [[ "$os" == "windows" ]]; then extension=".exe"; fi
  printf 'tinytop-agent-%s-%s%s\n' "$os" "$arch" "$extension"
}

rust_release_download_url() {
  printf 'https://github.com/michelabboud/tinytop/releases/download/v%s/%s\n' "$TINYTOP_VERSION" "$(rust_release_asset_name)"
}

history_db_path() {
  if [[ -n "${TINYTOP_HISTORY_DB:-}" ]]; then
    printf '%s\n' "$TINYTOP_HISTORY_DB"
    return
  fi
  local data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  printf '%s\n' "$data_home/tinytop/history.sqlite"
}

backup_dir_path() {
  local data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  date +"$data_home/tinytop/backups/%Y%m%d-%H%M%S"
}

dashboard_url() {
  printf 'http://%s:%s\n' "${HOST:-127.0.0.1}" "${PORT:-4274}"
}

collector_url() {
  printf 'http://%s:%s\n' "${HISTORY_WRITER_HOST:-127.0.0.1}" "${HISTORY_WRITER_PORT:-4276}"
}

runtime_state_dir() {
  if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    printf '%s/tinytop\n' "$XDG_RUNTIME_DIR"
  else
    printf '%s/tinytop\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
  fi
}

runtime_root_id() {
  printf '%s' "$ROOT_DIR" | cksum | awk '{print $1}'
}

runtime_pid_file() {
  printf '%s/%s.pid\n' "$(runtime_state_dir)" "$(runtime_root_id)"
}

write_runtime_pid_file() {
  local pid_file
  pid_file="$(runtime_pid_file)"
  mkdir -p "$(dirname "$pid_file")"
  printf '%s\n' "$$" > "$pid_file"
}

runtime_pid_from_file() {
  local pid_file pid
  pid_file="$(runtime_pid_file)"
  [[ -f "$pid_file" ]] || return 1
  read -r pid < "$pid_file" || return 1
  if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
    printf '%s\n' "$pid"
    return 0
  fi
  rm -f "$pid_file"
  return 1
}

clear_runtime_pid_file() {
  rm -f "$(runtime_pid_file)"
}

json_field() {
  local json="$1"
  local field="$2"
  local pattern
  pattern="\"${field}\"[[:space:]]*:[[:space:]]*\"([^\"]*)\""
  if [[ "$json" =~ $pattern ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  fi
}

running_daemon_version() {
  local curl_bin
  curl_bin="$(curl_path)"
  [[ -n "$curl_bin" ]] || return 1

  local body
  body="$("$curl_bin" -fsS --max-time 1 "$(dashboard_url)/api/version" 2>/dev/null)" || return 1

  local version runtime component dashboard
  version="$(json_field "$body" "version")"
  runtime="$(json_field "$body" "runtime")"
  component="$(json_field "$body" "component")"
  dashboard="$(json_field "$body" "dashboard")"
  [[ -n "$version" && -n "$runtime" ]] || return 1
  [[ -n "$component" ]] || component="daemon"

  if [[ -n "$dashboard" && "$dashboard" != "none" ]]; then
    printf '%s %s v%s (%s dashboard)\n' "$runtime" "$component" "$version" "$dashboard"
  else
    printf '%s %s v%s\n' "$runtime" "$component" "$version"
  fi
}

print_banner() {
  say "${C_BOLD}TinyTop${C_RESET} ${TINYTOP_VERSION}"
  say "Tiny local WSL/Linux status dashboard"
}

print_help() {
  print_banner
  cat <<'EOF'

Usage:
  ./tinytop help
  ./tinytop setup
  ./tinytop install-bun [--print-only|--yes]
  ./tinytop install-rust [--print-only]
  ./tinytop doctor
  ./tinytop deps
  ./tinytop check
  ./tinytop start
  ./tinytop start:split
  ./tinytop restart
  ./tinytop stop
  ./tinytop status
  ./tinytop logs
  ./tinytop monitor [seconds]
  ./tinytop stats
  ./tinytop rust collect|serve|serve-writer|build|test|check|install-binary
  ./tinytop db stats|check|backup|vacuum|reset [--yes]
  ./tinytop systemd render [--rust|--bun]
  ./tinytop systemd install [--rust|--bun] [--now]
  ./tinytop systemd uninstall|start|stop|restart|status|logs

Common operations:
  ./tinytop rust install-binary
  ./tinytop systemd install --rust
  ./tinytop db backup

Fresh install:
  ./tinytop rust install-binary
  # or: ./tinytop install-rust --print-only && ./tinytop rust build
  ./tinytop setup

The Bash command center works before Bun is installed. Rust systemd mode can
run the dashboard without Bun by using a release binary or a local Cargo build.
Once Bun exists, ./tinytop setup runs the richer Bun wizard with:

  bun run setup

Default URLs:
  Dashboard: http://127.0.0.1:4274
  Legacy collector API: http://127.0.0.1:4276

Default SQLite:
  ~/.local/share/tinytop/history.sqlite
EOF
}

print_bun_help() {
  cat <<EOF
Install Bun before running TinyTop runtime commands:
  $INSTALL_BUN_COMMAND
  bun --version

Official links:
  Website/docs: https://bun.sh
  Installation docs: https://bun.sh/docs/installation
  GitHub repository: https://github.com/oven-sh/bun
EOF
}

print_rust_help() {
  cat <<EOF
Rust powers the no-Bun TinyTop daemon path.

Install Rust/Cargo when compiling locally:
  $INSTALL_RUST_COMMAND
  cargo --version

Install the TinyTop Rust collector binary from GitHub release assets:
  ./tinytop rust install-binary

Compile locally:
  ./tinytop rust build

Run:
  ./tinytop rust serve
  ./tinytop rust serve-writer
  ./tinytop rust collect

Official Rust installer:
  https://rustup.rs
EOF
}

cmd_install_bun() {
  case "${1:-}" in
    --help|-h)
      print_bun_help
      ;;
    --print-only)
      say "$INSTALL_BUN_COMMAND"
      ;;
    --yes)
      if [[ -n "$(bun_path)" ]]; then
        ok "Bun is already installed: $(bun --version)"
        return 0
      fi
      command -v curl >/dev/null 2>&1 || die "curl is required to install Bun. Install curl first, then rerun ./tinytop install-bun --yes"
      info "Installing Bun with the official installer:"
      say "  $INSTALL_BUN_COMMAND"
      curl -fsSL https://bun.com/install | bash
      say
      say "Restart your shell or run:"
      # shellcheck disable=SC2016
      say '  export BUN_INSTALL="$HOME/.bun"'
      # shellcheck disable=SC2016
      say '  export PATH="$BUN_INSTALL/bin:$PATH"'
      say "  bun --version"
      ;;
    "")
      print_bun_help
      say
      say "Use --yes to run the installer, or --print-only to inspect the command."
      ;;
    *)
      die "Unknown install-bun option: $1"
      ;;
  esac
}

cmd_install_rust() {
  case "${1:-}" in
    --help|-h)
      print_rust_help
      ;;
    --print-only|"")
      say "$INSTALL_RUST_COMMAND"
      ;;
    *)
      die "Unknown install-rust option: $1"
      ;;
  esac
}

cmd_rust_install_binary() {
  local curl_bin
  curl_bin="$(curl_path)"
  [[ -n "$curl_bin" ]] || die "curl is required to install the TinyTop Rust collector release binary."

  local destination temp url
  destination="$(rust_agent_local_bin)"
  url="${1:-$(rust_release_download_url)}"
  temp="$(mktemp)"
  mkdir -p "$(dirname "$destination")"

  info "Downloading TinyTop Rust collector binary:"
  say "  $url"
  if ! "$curl_bin" -fL "$url" -o "$temp"; then
    rm -f "$temp"
    die "Could not download a prebuilt TinyTop Rust collector binary for this platform.
Fallback: install Rust and run ./tinytop rust build"
  fi

  chmod 0755 "$temp"
  mv "$temp" "$destination"
  ok "Installed TinyTop Rust collector binary: $destination"
}

rust_build_args() {
  local -a args=(build --release --manifest-path agent/Cargo.toml -p tinytop-agent)
  case "$(rust_release_os)" in
    macos) args+=(--no-default-features --features macos-collector) ;;
    windows) args+=(--no-default-features --features windows-collector) ;;
  esac
  printf '%s\n' "${args[@]}"
}

print_cargo_command() {
  printf 'cargo'
  for arg in "$@"; do
    printf ' %s' "$arg"
  done
  printf '\n'
}

cmd_rust_build() {
  local print_command=0
  for arg in "$@"; do
    case "$arg" in
      --print-command) print_command=1 ;;
      *) die "Unknown rust build option: $arg" ;;
    esac
  done

  local -a args
  mapfile -t args < <(rust_build_args)
  if [[ "$print_command" -eq 1 ]]; then
    print_cargo_command "${args[@]}"
    return 0
  fi

  require_cargo
  cd "$ROOT_DIR"
  cargo "${args[@]}"
  ok "Built TinyTop Rust collector binary: $(rust_agent_target_bin)"
}

cmd_rust_test() {
  require_cargo
  cd "$ROOT_DIR"
  cargo test --manifest-path agent/Cargo.toml --workspace
}

cmd_rust_check() {
  require_cargo
  cd "$ROOT_DIR"
  cargo fmt --manifest-path agent/Cargo.toml --all -- --check
  cargo test --manifest-path agent/Cargo.toml --workspace
}

cmd_rust_collect() {
  local agent_bin
  agent_bin="$(rust_agent_exec)"
  if [[ -x "$agent_bin" ]]; then
    exec "$agent_bin" collect --json "$@"
  fi

  require_cargo
  cd "$ROOT_DIR"
  cargo run --manifest-path agent/Cargo.toml -p tinytop-agent -- collect --json "$@"
}

cmd_rust_serve() {
  local subcommand="$1"
  shift || true

  local agent_bin
  agent_bin="$(rust_agent_exec)"

  if [[ "$subcommand" == "serve" || "$subcommand" == "serve-writer" ]]; then
    write_runtime_pid_file
  fi

  if [[ -x "$agent_bin" ]]; then
    exec "$agent_bin" "$subcommand" "$@"
  fi

  require_cargo
  cd "$ROOT_DIR"
  exec cargo run --manifest-path agent/Cargo.toml -p tinytop-agent -- "$subcommand" "$@"
}

cmd_rust() {
  local sub="${1:-help}"
  if [[ "$#" -gt 0 ]]; then shift; fi
  case "$sub" in
    collect) cmd_rust_collect "$@" ;;
    serve) cmd_rust_serve serve "$@" ;;
    serve-writer) cmd_rust_serve serve-writer "$@" ;;
    build) cmd_rust_build "$@" ;;
    test) cmd_rust_test ;;
    check) cmd_rust_check ;;
    install-binary) cmd_rust_install_binary "$@" ;;
    help|-h|--help) print_rust_help ;;
    *) die "Unknown rust command: $sub" ;;
  esac
}

status_line() {
  local label="$1"
  local value="$2"
  printf '%s: %s\n' "$label" "$value"
}

port_status() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    if ss -ltn "( sport = :$port )" 2>/dev/null | tail -n +2 | grep -q .; then
      printf 'listening'
    else
      printf 'free'
    fi
  else
    printf 'unknown (ss missing)'
  fi
}

systemd_user_available() {
  command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1
}

unit_path() {
  printf '%s/.config/systemd/user/%s\n' "$HOME" "$1"
}

unit_installed() {
  [[ -f "$(unit_path "$1")" ]]
}

cmd_doctor() {
  print_banner
  say
  local bun_bin
  bun_bin="$(bun_path)"
  if [[ -n "$bun_bin" ]]; then
    status_line "Bun" "ok ($("$bun_bin" --version) at $bun_bin)"
  else
    status_line "Bun" "missing"
    say "  Install with: ./tinytop install-bun --yes"
  fi

  local cargo_bin
  cargo_bin="$(cargo_path)"
  if [[ -n "$cargo_bin" ]]; then
    status_line "Rust/Cargo" "ok ($("$cargo_bin" --version) at $cargo_bin)"
  else
    status_line "Rust/Cargo" "missing"
    say "  Install with: $INSTALL_RUST_COMMAND"
    say "  Docs: https://rustup.rs"
  fi

  local agent_bin
  agent_bin="$(rust_agent_exec)"
  if [[ -x "$agent_bin" ]]; then
    status_line "Rust collector binary" "ok ($agent_bin)"
  else
    status_line "Rust collector binary" "missing (run ./tinytop rust install-binary or ./tinytop rust build)"
  fi

  if [[ -d "$ROOT_DIR/node_modules" ]]; then
    status_line "Dependencies" "installed"
  else
    status_line "Dependencies" "missing (run ./tinytop deps)"
  fi

  status_line "Dashboard URL" "$(dashboard_url)"
  status_line "Collector API URL" "$(collector_url)"
  status_line "Dashboard port" "$(port_status "${PORT:-4274}")"
  status_line "Collector API port" "$(port_status "${HISTORY_WRITER_PORT:-4276}")"
  local running_version
  if running_version="$(running_daemon_version)"; then
    status_line "Running daemon" "$running_version"
  else
    status_line "Running daemon" "unknown (/api/version unavailable)"
  fi
  status_line "SQLite DB" "$(history_db_path)"

  if systemd_user_available; then
    status_line "systemd user" "available"
  else
    status_line "systemd user" "unavailable"
  fi

  local collector_state="not installed"
  local dashboard_state="not installed"
  local daemon_state="not installed"
  unit_installed "tinytop.service" && daemon_state="installed"
  unit_installed "tinytop-collector.service" && collector_state="installed"
  unit_installed "tinytop-writer.service" && collector_state="installed (legacy writer unit name)"
  unit_installed "tinytop-dashboard.service" && dashboard_state="installed"
  status_line "rust collector/dashboard service" "$daemon_state"
  status_line "legacy Bun collector service" "$collector_state"
  status_line "dashboard service" "$dashboard_state"
}

cmd_setup() {
  local bun_bin
  bun_bin="$(bun_path)"
  if [[ -z "$bun_bin" ]]; then
    fail "Bun is required before the Bun setup wizard can run."
    fail "Run: ./tinytop install-bun --yes"
    return 1
  fi

  cd "$ROOT_DIR"
  if [[ ! -d "$ROOT_DIR/node_modules" ]]; then
    info "Dependencies are missing; running bun install first."
    "$bun_bin" install
  fi

  exec "$bun_bin" run setup "$@"
}

cmd_deps() {
  require_bun
  cd "$ROOT_DIR"
  bun install
}

cmd_check() {
  require_bun
  cd "$ROOT_DIR"
  bun run check
  bun build legacy/dashboard/app.js --target=browser --outdir=/tmp/tinytop-build-check
}

cmd_start() {
  local runtime
  runtime="$(selected_runtime)"
  if [[ "$runtime" == "rust" ]]; then
    info "Auto-selected Rust collector/dashboard daemon."
    cmd_rust_serve serve "$@"
  fi

  info "Auto-selected legacy Bun dashboard."
  require_bun
  cd "$ROOT_DIR"
  write_runtime_pid_file
  exec "$(bun_path)" run dev "$@"
}

cmd_start_split() {
  require_bun
  cd "$ROOT_DIR"
  write_runtime_pid_file
  info "Starting TinyTop legacy Bun collector in the background."
  bun run collector &
  local collector_pid=$!
  trap 'kill "$collector_pid" 2>/dev/null || true' EXIT INT TERM
  info "Starting TinyTop dashboard with collector auto-spawn disabled."
  TINYTOP_DISABLE_WRITER_SPAWN=1 bun run dev
}

systemd_bun_exec() {
  local bun_bin
  bun_bin="$(bun_path)"
  if [[ -n "$bun_bin" ]]; then
    printf '%s' "$bun_bin"
  else
    printf '/usr/bin/env bun'
  fi
}

render_bun_collector_unit() {
  local bun_exec
  bun_exec="$(systemd_bun_exec)"
  cat <<EOF
[Unit]
Description=TinyTop legacy Bun collector
After=network-online.target

[Service]
Type=simple
WorkingDirectory=$ROOT_DIR
ExecStart=$bun_exec run legacy/bun-collector.ts
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF
}

render_rust_daemon_unit() {
  local agent_exec
  agent_exec="$(rust_agent_exec)"
  cat <<EOF
[Unit]
Description=TinyTop Rust collector and dashboard daemon
After=network-online.target

[Service]
Type=simple
WorkingDirectory=$ROOT_DIR
ExecStart=$agent_exec serve --host ${HOST:-127.0.0.1} --port ${PORT:-4274}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF
}

render_dashboard_unit() {
  local bun_exec
  bun_exec="$(systemd_bun_exec)"
  cat <<EOF
[Unit]
Description=TinyTop dashboard
After=network-online.target tinytop-collector.service
Requires=tinytop-collector.service

[Service]
Type=simple
WorkingDirectory=$ROOT_DIR
Environment=TINYTOP_DISABLE_WRITER_SPAWN=1
ExecStart=$bun_exec run src/server.ts
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF
}

systemd_mode_from_args() {
  local mode="rust"
  for arg in "$@"; do
    case "$arg" in
      --rust) mode="rust" ;;
      --bun) mode="bun" ;;
    esac
  done
  printf '%s\n' "$mode"
}

cmd_systemd_render() {
  local mode
  mode="$(systemd_mode_from_args "$@")"
  if [[ "$mode" == "bun" ]]; then
    say "# ~/.config/systemd/user/tinytop-collector.service"
    render_bun_collector_unit
    say
    say "# ~/.config/systemd/user/tinytop-dashboard.service"
    render_dashboard_unit
  else
    say "# ~/.config/systemd/user/tinytop.service"
    render_rust_daemon_unit
  fi
}

ensure_rust_agent_for_systemd() {
  local agent_exec
  agent_exec="$(rust_agent_exec)"
  if [[ -x "$agent_exec" ]]; then
    return 0
  fi

  info "Rust collector binary is missing; building it locally."
  cmd_rust_build
}

cmd_systemd_install() {
  command -v systemctl >/dev/null 2>&1 || die "systemctl is not available."
  local mode
  mode="$(systemd_mode_from_args "$@")"
  local unit_dir="$HOME/.config/systemd/user"
  mkdir -p "$unit_dir"
  if [[ "$mode" == "bun" ]]; then
    require_bun
    render_bun_collector_unit > "$unit_dir/tinytop-collector.service"
    render_dashboard_unit > "$unit_dir/tinytop-dashboard.service"
    systemctl --user daemon-reload
    systemctl --user enable tinytop-collector.service tinytop-dashboard.service
    ok "Installed and enabled TinyTop legacy Bun collector services."
  else
    ensure_rust_agent_for_systemd
    render_rust_daemon_unit > "$unit_dir/tinytop.service"
    systemctl --user daemon-reload
    systemctl --user enable tinytop.service
    ok "Installed and enabled TinyTop Rust user service."
  fi
  if [[ " $* " == *" --now "* ]]; then
    if [[ "$mode" == "bun" ]]; then
      systemctl --user start tinytop-collector.service tinytop-dashboard.service
    else
      systemctl --user start tinytop.service
    fi
    ok "Started TinyTop user services."
  else
    say "Start with: ./tinytop systemd start"
  fi
}

cmd_systemd_uninstall() {
  command -v systemctl >/dev/null 2>&1 || die "systemctl is not available."
  systemctl --user disable --now tinytop.service tinytop-dashboard.service tinytop-collector.service tinytop-writer.service 2>/dev/null || true
  rm -f "$(unit_path tinytop.service)" "$(unit_path tinytop-dashboard.service)" "$(unit_path tinytop-collector.service)" "$(unit_path tinytop-writer.service)"
  systemctl --user daemon-reload
  ok "Removed TinyTop user services."
}

systemd_action_units() {
  if unit_installed "tinytop.service"; then
    printf '%s\n' "tinytop.service"
    return
  fi

  local found=0
  if unit_installed "tinytop-collector.service"; then
    printf '%s\n' "tinytop-collector.service"
    found=1
  elif unit_installed "tinytop-writer.service"; then
    printf '%s\n' "tinytop-writer.service"
    found=1
  fi
  if unit_installed "tinytop-dashboard.service"; then
    printf '%s\n' "tinytop-dashboard.service"
    found=1
  fi
  if [[ "$found" -eq 0 ]]; then
    printf '%s\n' "tinytop.service"
  fi
}

cmd_systemd_action() {
  command -v systemctl >/dev/null 2>&1 || die "systemctl is not available."
  local action="$1"
  local -a units
  mapfile -t units < <(systemd_action_units)
  systemctl --user "$action" "${units[@]}"
}

cmd_systemd_logs() {
  command -v journalctl >/dev/null 2>&1 || die "journalctl is not available."
  if unit_installed "tinytop.service"; then
    journalctl --user -u tinytop.service -f
  elif unit_installed "tinytop-collector.service"; then
    journalctl --user -u tinytop-collector.service -u tinytop-dashboard.service -f
  else
    journalctl --user -u tinytop-writer.service -u tinytop-dashboard.service -f
  fi
}

cmd_systemd() {
  local sub="${1:-help}"
  if [[ "$#" -gt 0 ]]; then shift; fi
  case "$sub" in
    render) cmd_systemd_render "$@" ;;
    install) cmd_systemd_install "$@" ;;
    uninstall) cmd_systemd_uninstall ;;
    start|stop|restart|status) cmd_systemd_action "$sub" ;;
    logs) cmd_systemd_logs ;;
    help|-h|--help)
      say "Usage: ./tinytop systemd render [--rust|--bun]"
      say "       ./tinytop systemd install [--rust|--bun] [--now]"
      say "       ./tinytop systemd uninstall|start|stop|restart|status|logs"
      ;;
    *) die "Unknown systemd command: $sub" ;;
  esac
}

cmd_db_backup() {
  local db
  db="$(history_db_path)"
  local destination
  destination="$(backup_dir_path)"
  mkdir -p "$destination"
  shopt -s nullglob
  local files=("$db" "$db-wal" "$db-shm")
  local copied=0
  for file in "${files[@]}"; do
    if [[ -e "$file" ]]; then
      cp -p "$file" "$destination/"
      copied=$((copied + 1))
    fi
  done
  if [[ "$copied" -eq 0 ]]; then
    warn "No SQLite files found at $db"
    rmdir "$destination" 2>/dev/null || true
    return 1
  fi
  ok "Backed up $copied file(s) to $destination"
}

cmd_db_reset() {
  local yes=0
  for arg in "$@"; do
    if [[ "$arg" == "--yes" ]]; then yes=1; fi
  done
  if [[ "$yes" -ne 1 ]]; then
    die "Refusing to reset history without --yes. Back up first with: ./tinytop db backup"
  fi
  local db
  db="$(history_db_path)"
  local archive
  archive="$(backup_dir_path)-reset"
  mkdir -p "$archive"
  shopt -s nullglob
  local files=("$db" "$db-wal" "$db-shm")
  local moved=0
  for file in "${files[@]}"; do
    if [[ -e "$file" ]]; then
      mv "$file" "$archive/"
      moved=$((moved + 1))
    fi
  done
  ok "Moved $moved SQLite file(s) to $archive"
}

cmd_db_runtime() {
  local sub="$1"
  shift || true

  local db
  db="$(history_db_path)"
  if [[ "$sub" != "vacuum" && ! -e "$db" ]]; then
    die "History database does not exist yet: $db"
  fi

  local agent_bin
  agent_bin="$(rust_agent_exec)"
  if [[ -x "$agent_bin" ]]; then
    "$agent_bin" db "$sub" --sqlite "$db" "$@"
    return
  fi

  if [[ -n "$(cargo_path)" ]]; then
    cd "$ROOT_DIR"
    cargo run --manifest-path agent/Cargo.toml -p tinytop-agent -- db "$sub" --sqlite "$db" "$@"
    return
  fi

  require_bun
  cd "$ROOT_DIR"
  bun run src/ops.ts db "$sub" "$@"
}

cmd_db() {
  local sub="${1:-help}"
  if [[ "$#" -gt 0 ]]; then shift; fi
  case "$sub" in
    backup) cmd_db_backup ;;
    reset) cmd_db_reset "$@" ;;
    stats|check|vacuum) cmd_db_runtime "$sub" "$@" ;;
    help|-h|--help)
      say "Usage: ./tinytop db stats|check|backup|vacuum|reset [--yes]"
      ;;
    *) die "Unknown db command: $sub" ;;
  esac
}

cmd_stats() {
  require_bun
  cd "$ROOT_DIR"
  bun run src/ops.ts stats "$@"
}

cmd_logs() {
  if unit_installed "tinytop.service" || unit_installed "tinytop-collector.service" || unit_installed "tinytop-writer.service" || unit_installed "tinytop-dashboard.service"; then
    cmd_systemd_logs
  else
    say "No TinyTop systemd units installed."
    say "Foreground logs appear in the terminal running ./tinytop rust serve, ./tinytop start, or ./tinytop start:split."
  fi
}

foreground_tinytop_pids() {
  local pid
  if pid="$(runtime_pid_from_file)"; then
    printf '%s\n' "$pid"
    return 0
  fi

  command -v pgrep >/dev/null 2>&1 || return 0
  pgrep -af '([t]inytop-agent serve|[s]rc/server\.ts|[l]egacy/bun-collector\.ts)' | awk -v root="$ROOT_DIR" '
    $0 ~ root { print $1 }
  '
}

cmd_restart() {
  if unit_installed "tinytop.service" || unit_installed "tinytop-collector.service" || unit_installed "tinytop-writer.service" || unit_installed "tinytop-dashboard.service"; then
    cmd_systemd_action restart
  else
    cmd_stop
    cmd_start "$@"
  fi
}

cmd_stop() {
  if unit_installed "tinytop.service" || unit_installed "tinytop-collector.service" || unit_installed "tinytop-writer.service" || unit_installed "tinytop-dashboard.service"; then
    cmd_systemd_action stop
  else
    local -a pids
    mapfile -t pids < <(foreground_tinytop_pids)
    if [[ "${#pids[@]}" -eq 0 ]]; then
      say "No TinyTop systemd units installed and no foreground TinyTop runtime was detected."
      return 0
    fi
    info "Stopping foreground TinyTop runtime process(es): ${pids[*]}"
    kill "${pids[@]}" 2>/dev/null || true
    clear_runtime_pid_file
    ok "Stopped foreground TinyTop runtime process(es)."
  fi
}

cmd_monitor() {
  local interval="${1:-2}"
  while true; do
    clear 2>/dev/null || true
    cmd_doctor
    say
    if [[ -n "$(bun_path)" ]]; then
      cmd_stats || true
    fi
    sleep "$interval"
  done
}

case "$command_name" in
  help|-h|--help) print_help ;;
  setup) cmd_setup "$@" ;;
  install-bun) cmd_install_bun "$@" ;;
  install-rust) cmd_install_rust "$@" ;;
  doctor|status) cmd_doctor ;;
  deps) cmd_deps ;;
  check) cmd_check ;;
  start) cmd_start "$@" ;;
  start:split) cmd_start_split "$@" ;;
  restart) cmd_restart "$@" ;;
  stop) cmd_stop ;;
  logs) cmd_logs ;;
  monitor) cmd_monitor "$@" ;;
  stats) cmd_stats "$@" ;;
  rust) cmd_rust "$@" ;;
  db) cmd_db "$@" ;;
  systemd) cmd_systemd "$@" ;;
  *)
    fail "Unknown command: $command_name"
    say
    print_help >&2
    exit 1
    ;;
esac
